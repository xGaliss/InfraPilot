{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Agent": {
    "DisplayName": "InfraPilot-Agent-Local",
    "AgentVersion": "0.1.0",
    "CentralBaseUrl": "http://localhost:5180",
    "EnrollmentKey": "infra-dev-enroll",
    "DataDirectory": "data\\agent",
    "HeartbeatIntervalSeconds": 30,
    "SnapshotIntervalSeconds": 60,
    "ActionPollIntervalSeconds": 5,
    "HttpTimeoutSeconds": 15
  },
  "Capabilities": {
    "Services": {
      "Enabled": true,
      "IncludeNames": [],
      "ExcludeNames": [
        "MicrosoftEdgeUpdate",
        "OneSync",
        "CDPUserSvc"
      ]
    },
    "ScheduledTasks": {
      "Enabled": true,
      "IncludePaths": [],
      "ExcludePaths": [
        "\\Microsoft\\",
        "\\Adobe\\"
      ]
    },
    "FileTree": {
      "Enabled": true,
      "MaxDepth": 2,
      "Roots": [
        "C:\\\\Temp"
      ]
    },
    "Iis": {
      "Enabled": true,
      "IncludeSites": [],
      "ExcludeSites": [],
      "IncludeAppPools": [],
      "ExcludeAppPools": []
    }
  }
}
