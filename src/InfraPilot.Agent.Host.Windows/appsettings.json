{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Agent": {
    "DisplayName": "InfraPilot-Agent-Local",
    "AgentVersion": "0.1.0",
    "CentralBaseUrl": "http://192.168.0.41:5180",
    "EnrollmentKey": "infra-dev-enroll",
    "DataDirectory": "data\\agent",
    "HeartbeatIntervalSeconds": 30,
    "SnapshotIntervalSeconds": 60,
    "ActionPollIntervalSeconds": 5,
    "HttpTimeoutSeconds": 15
  },
  "Capabilities": {
    "Services": {
      "Enabled": true,
      "IncludeNames": [
        "Windows"
      ],
      "ExcludeNames": []
    },
    "ScheduledTasks": {
      "Enabled": true,
      "IncludePaths": [
        "\\Prueba\\"
      ],
      "ExcludePaths": []
    },
    "FileTree": {
      "Enabled": true,
      "MaxDepth": 3,
      "Roots": [
        "C:\\\\InfraPilot"
      ]
    },
    "Iis": {
      "Enabled": true,
      "IncludeSites": [],
      "ExcludeSites": [],
      "IncludeAppPools": [],
      "ExcludeAppPools": []
    }
  }
}
