@using InfraPilot.Contracts.Capabilities
@model IReadOnlyList<CapabilitySnapshotHistoryItemDto>

@{
    var changedSnapshots = Model
        .Where(item => item.ChangeSummary.HasChanges)
        .OrderByDescending(item => item.CollectedUtc)
        .ToList();
}

<section class="history-shell">
    <div class="section-heading compact-heading">
        <div>
            <p class="eyebrow">History</p>
            <h2>Changed captures</h2>
        </div>
    </div>

    @if (changedSnapshots.Count == 0)
    {
        <p class="empty-state">No changed snapshots have been recorded for this capability yet.</p>
    }
    else
    {
        <div class="history-list">
            @foreach (var item in changedSnapshots)
            {
                <article class="history-item">
                    <div class="history-item-head">
                        <div class="history-item-title">
                            <strong>@item.CollectedUtc.ToLocalTime().ToString("g")</strong>
                            <span class="muted">
                                Compared with @(item.ChangeSummary.PreviousCollectedUtc?.ToLocalTime().ToString("g") ?? "the previous snapshot")
                            </span>
                        </div>
                        <span class="timestamp-chip">Changed</span>
                    </div>

                    <p class="capability-preview">@item.ChangeSummary.Summary</p>

                    @if (item.ChangeSummary.Highlights.Count > 0)
                    {
                        <div class="change-highlight-list">
                            @foreach (var highlight in item.ChangeSummary.Highlights)
                            {
                                <span class="change-highlight-chip">@highlight</span>
                            }
                        </div>
                    }
                </article>
            }
        </div>
    }
</section>
