@model IReadOnlyList<InfraPilot.Web.Pages.Agents.DetailsModel.CapabilityHistoryEntryViewModel>

@{
    var changedSnapshots = Model
        .OrderByDescending(item => item.Item.CollectedUtc)
        .ToList();
}

<section class="history-shell">
    <div class="section-heading compact-heading">
        <div>
            <p class="eyebrow">History</p>
            <h2>Changed captures</h2>
        </div>
    </div>

    @if (changedSnapshots.Count == 0)
    {
        <p class="empty-state">No changed snapshots have been recorded for this capability yet.</p>
    }
    else
    {
        <div class="history-list">
            @foreach (var item in changedSnapshots)
            {
                <details class="history-item">
                    <summary class="history-item-summary">
                        <div class="history-item-head">
                            <div class="history-item-title">
                                <strong>@item.Item.CollectedUtc.ToLocalTime().ToString("g")</strong>
                                <span class="muted">
                                    Compared with @(item.Item.ChangeSummary.PreviousCollectedUtc?.ToLocalTime().ToString("g") ?? "the previous snapshot")
                                </span>
                            </div>
                            <div class="history-item-actions">
                                <span class="timestamp-chip">Changed</span>
                                <span class="btn btn-sm btn-outline-secondary history-toggle">View change</span>
                            </div>
                        </div>

                        <p class="capability-preview">@item.Item.ChangeSummary.Summary</p>
                    </summary>

                    <div class="history-item-body">
                        @if (item.Item.ChangeSummary.Highlights.Count > 0)
                        {
                            <div class="change-highlight-list">
                                @foreach (var highlight in item.Item.ChangeSummary.Highlights)
                                {
                                    <span class="change-highlight-chip">@highlight</span>
                                }
                            </div>
                        }

                        @if (item.Sections.Count == 0)
                        {
                            <p class="empty-state">No detailed diff lines were generated for this capture.</p>
                        }
                        else
                        {
                            <div class="history-section-list">
                                @foreach (var diffSection in item.Sections)
                                {
                                    <section class="history-diff-section">
                                        <h3>@diffSection.Title</h3>
                                        <ul class="history-diff-lines">
                                            @foreach (var line in diffSection.Lines)
                                            {
                                                <li>@line</li>
                                            }
                                        </ul>
                                    </section>
                                }
                            </div>
                        }
                    </div>
                </details>
            }
        </div>
    }
</section>
