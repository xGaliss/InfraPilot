<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - InfraPilot</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/InfraPilot.Web.styles.css" asp-append-version="true" />
</head>
@{
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? string.Empty;
    var isFleetPage = string.Equals(currentPage, "/Index", StringComparison.OrdinalIgnoreCase);
    var isActivityPage = string.Equals(currentPage, "/Activity", StringComparison.OrdinalIgnoreCase);
}
<body>
    <div class="app-shell">
        <header class="app-header">
            <div class="app-header-inner">
                <div class="brand-block">
                    <a class="brand-logo-link" asp-area="" asp-page="/Index">
                        <img src="~/brand/infrahub-logo-nobg.svg" alt="InfraPilot logo" class="brand-logo" />
                    </a>
                    <div>
                        <a class="brand-name" asp-area="" asp-page="/Index">InfraPilot</a>
                        <div class="brand-tagline">Agent-first server operations</div>
                    </div>
                </div>

                <nav class="top-nav">
                    <a class="top-nav-link @(isFleetPage ? "active" : null)" asp-area="" asp-page="/Index">Fleet</a>
                    <a class="top-nav-link @(isActivityPage ? "active" : null)" asp-area="" asp-page="/Activity">Activity</a>
                </nav>
            </div>
        </header>

        <div class="app-canvas">
            <main role="main" class="page-content">
                @RenderBody()
            </main>
        </div>

        <footer class="app-footer">
            <div class="footer-content">
                <span>InfraPilot control plane</span>
                <span>Pull-based orchestration for Windows agents</span>
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
