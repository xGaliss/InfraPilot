@page "{id:guid}/{section?}"
@using InfraPilot.Contracts.Capabilities
@model InfraPilot.Web.Pages.Agents.DetailsModel
@{
    ViewData["Title"] = "Agent Workspace";
    var services = Model.ServicesSnapshot.Services ?? [];
    var scheduledTasks = Model.ScheduledTasksSnapshot.Tasks ?? [];
    var appPools = Model.IisSnapshot.AppPools ?? [];
    var sites = Model.IisSnapshot.Sites ?? [];
    var users = Model.UsersAndGroupsSnapshot.Users ?? [];
    var groups = Model.UsersAndGroupsSnapshot.Groups ?? [];
    var hasServices = false;
    var hasScheduledTasks = false;
    var hasIis = false;
    var hasFileTree = false;
    var hasUsersAndGroups = false;
    InfraPilot.Contracts.Capabilities.AgentCapabilityStateDto? serviceState = null;
    InfraPilot.Contracts.Capabilities.AgentCapabilityStateDto? scheduledTaskState = null;
    InfraPilot.Contracts.Capabilities.AgentCapabilityStateDto? iisState = null;
    InfraPilot.Contracts.Capabilities.AgentCapabilityStateDto? fileTreeState = null;
    InfraPilot.Contracts.Capabilities.AgentCapabilityStateDto? usersAndGroupsState = null;
    IReadOnlyList<InfraPilot.Contracts.Capabilities.AgentCapabilityStateDto> changedCapabilities = [];
    var healthClass = "health-neutral";

    if (Model.Agent is not null)
    {
        hasServices = Model.Agent.Capabilities.Any(x => x.Descriptor.CapabilityKey == CapabilityKeys.Services);
        hasScheduledTasks = Model.Agent.Capabilities.Any(x => x.Descriptor.CapabilityKey == CapabilityKeys.ScheduledTasks);
        hasIis = Model.Agent.Capabilities.Any(x => x.Descriptor.CapabilityKey == CapabilityKeys.Iis);
        hasFileTree = Model.Agent.Capabilities.Any(x => x.Descriptor.CapabilityKey == CapabilityKeys.FileTree);
        hasUsersAndGroups = Model.Agent.Capabilities.Any(x => x.Descriptor.CapabilityKey == CapabilityKeys.UsersAndGroups);
        serviceState = Model.Agent.Capabilities.FirstOrDefault(x => x.Descriptor.CapabilityKey == CapabilityKeys.Services);
        scheduledTaskState = Model.Agent.Capabilities.FirstOrDefault(x => x.Descriptor.CapabilityKey == CapabilityKeys.ScheduledTasks);
        iisState = Model.Agent.Capabilities.FirstOrDefault(x => x.Descriptor.CapabilityKey == CapabilityKeys.Iis);
        fileTreeState = Model.Agent.Capabilities.FirstOrDefault(x => x.Descriptor.CapabilityKey == CapabilityKeys.FileTree);
        usersAndGroupsState = Model.Agent.Capabilities.FirstOrDefault(x => x.Descriptor.CapabilityKey == CapabilityKeys.UsersAndGroups);
        changedCapabilities = Model.Agent.Capabilities
            .Where(x => x.ChangeSummary.HasPreviousSnapshot)
            .OrderByDescending(x => x.ChangeSummary.HasChanges)
            .ThenBy(x => x.Descriptor.DisplayName)
            .ToList();
        healthClass = Model.Agent.HealthStatus switch
        {
            "Healthy" => "health-good",
            "Delayed" => "health-warn",
            "Offline" => "health-bad",
            "NeedsApproval" => "health-neutral",
            "Revoked" => "health-bad",
            _ => "health-neutral"
        };
    }
}

@if (Model.Agent is not null)
{
    <div class="agent-page">
        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <section class="flash-banner @(Model.StatusTone == "error" ? "flash-error" : "flash-success")">
                @Model.StatusMessage
            </section>
        }

        <section class="hero-card agent-overview-card">
            <div>
                <p class="eyebrow">Agent Overview</p>
                <h1>@Model.Agent.DisplayName</h1>
                <div class="hero-meta-stack">
                    <p class="hero-meta">@Model.Agent.MachineName · @Model.Agent.Status · Last seen @(Model.Agent.LastSeenUtc?.ToLocalTime().ToString("g") ?? "-")</p>
                    <div class="hero-chip-row">
                        <span class="status-chip @healthClass">@Model.Agent.HealthStatus</span>
                        <span class="timestamp-chip">Last snapshot @(Model.Agent.LastCollectedUtc?.ToLocalTime().ToString("g") ?? "-")</span>
                    </div>
                </div>
            </div>

            <div class="hero-actions">
                @if (Model.Agent.Status == "Pending")
                {
                    <form method="post" asp-page-handler="Approve">
                        <input type="hidden" name="agentId" value="@Model.Agent.AgentId" />
                        <input type="hidden" name="section" value="@Model.SelectedSection" />
                        <button type="submit" class="btn btn-primary">Approve agent</button>
                    </form>
                }
                <a asp-page="/Index" class="btn btn-outline-secondary">Back to fleet</a>
            </div>
        </section>

        <section class="summary-grid">
            <article class="summary-card"><span class="summary-label">Capabilities</span><strong>@Model.Agent.Capabilities.Count</strong></article>
            <article class="summary-card"><span class="summary-label">Queued Actions</span><strong>@Model.Agent.PendingActionCount</strong></article>
            <article class="summary-card"><span class="summary-label">Running Actions</span><strong>@Model.Agent.InProgressActionCount</strong></article>
            <article class="summary-card"><span class="summary-label">Recent Failures</span><strong>@Model.Agent.FailedActionCount</strong></article>
            <article class="summary-card"><span class="summary-label">Services</span><strong>@services.Count</strong></article>
            <article class="summary-card"><span class="summary-label">Tasks</span><strong>@scheduledTasks.Count</strong></article>
            <article class="summary-card"><span class="summary-label">IIS Sites</span><strong>@sites.Count</strong></article>
            <article class="summary-card"><span class="summary-label">App Pools</span><strong>@appPools.Count</strong></article>
            <article class="summary-card"><span class="summary-label">Users</span><strong>@users.Count</strong></article>
            <article class="summary-card"><span class="summary-label">Groups</span><strong>@groups.Count</strong></article>
            <article class="summary-card"><span class="summary-label">Roots</span><strong>@Model.FileTreeSnapshot.Roots.Count</strong></article>
        </section>

        <section class="agent-workspace-shell">
            <div class="section-heading">
                <div>
                    <p class="eyebrow">Agent Workspace</p>
                    <h2>Overview first, capability views after that</h2>
                </div>
            </div>

            <div class="agent-workspace-grid">
                <aside class="agent-context-nav-shell">
                    <div class="agent-context-nav-sticky">
                        <div class="agent-context-nav-head">
                            <p class="eyebrow">Sections</p>
                            <h3>Agent Workspace</h3>
                        </div>

                        <nav class="agent-section-nav">
                            <a class="agent-section-link @(Model.SelectedSection == DetailsModel.OverviewSection ? "active" : null)"
                               asp-page="/Agents/Details"
                               asp-route-id="@Model.Agent.AgentId"
                               asp-route-section="@(null)">
                                <span>Overview</span>
                            </a>

                            @if (hasServices)
                            {
                                <a class="agent-section-link @(Model.SelectedSection == DetailsModel.ServicesSection ? "active" : null)"
                                   asp-page="/Agents/Details"
                                   asp-route-id="@Model.Agent.AgentId"
                                   asp-route-section="@DetailsModel.ServicesSection">
                                    <span>Services</span>
                                    <span class="tab-count">@services.Count</span>
                                </a>
                            }

                            @if (hasScheduledTasks)
                            {
                                <a class="agent-section-link @(Model.SelectedSection == DetailsModel.TasksSection ? "active" : null)"
                                   asp-page="/Agents/Details"
                                   asp-route-id="@Model.Agent.AgentId"
                                   asp-route-section="@DetailsModel.TasksSection">
                                    <span>Tasks</span>
                                    <span class="tab-count">@scheduledTasks.Count</span>
                                </a>
                            }

                            @if (hasIis)
                            {
                                <a class="agent-section-link @(Model.SelectedSection == DetailsModel.IisSection ? "active" : null)"
                                   asp-page="/Agents/Details"
                                   asp-route-id="@Model.Agent.AgentId"
                                   asp-route-section="@DetailsModel.IisSection">
                                    <span>IIS</span>
                                    <span class="tab-count">@(@sites.Count + @appPools.Count)</span>
                                </a>
                            }

                            @if (hasFileTree)
                            {
                                <a class="agent-section-link @(Model.SelectedSection == DetailsModel.FileTreeSection ? "active" : null)"
                                   asp-page="/Agents/Details"
                                   asp-route-id="@Model.Agent.AgentId"
                                   asp-route-section="@DetailsModel.FileTreeSection">
                                    <span>File Tree</span>
                                    <span class="tab-count">@Model.FileTreeSnapshot.Roots.Count</span>
                                </a>
                            }

                            @if (hasUsersAndGroups)
                            {
                                <a class="agent-section-link @(Model.SelectedSection == DetailsModel.UsersAndGroupsSection ? "active" : null)"
                                   asp-page="/Agents/Details"
                                   asp-route-id="@Model.Agent.AgentId"
                                   asp-route-section="@DetailsModel.UsersAndGroupsSection">
                                    <span>Users &amp; Groups</span>
                                    <span class="tab-count">@(users.Count + groups.Count)</span>
                                </a>
                            }

                            <a class="agent-section-link @(Model.SelectedSection == DetailsModel.ActionsSection ? "active" : null)"
                               asp-page="/Agents/Details"
                               asp-route-id="@Model.Agent.AgentId"
                               asp-route-section="@DetailsModel.ActionsSection">
                                <span>Actions</span>
                                <span class="tab-count">@Model.Agent.RecentActions.Count</span>
                            </a>
                        </nav>
                    </div>
                </aside>

                <div class="agent-section-content">
                    @if (Model.SelectedSection == DetailsModel.OverviewSection)
                    {
                        <article class="capability-card polished">
                            <div class="overview-grid">
                                @if (hasServices)
                                {
                                    <section class="overview-card"><div class="overview-card-head"><h3>Windows Services</h3><span class="timestamp-chip">@services.Count visible</span></div><p class="capability-preview">Manage services in a focused view with start, stop and restart actions.</p></section>
                                }
                                @if (hasScheduledTasks)
                                {
                                    <section class="overview-card"><div class="overview-card-head"><h3>Scheduled Tasks</h3><span class="timestamp-chip">@scheduledTasks.Count visible</span></div><p class="capability-preview">Run tasks on demand from their own operational view.</p></section>
                                }
                                @if (hasIis)
                                {
                                    <section class="overview-card"><div class="overview-card-head"><h3>IIS</h3><span class="timestamp-chip">@sites.Count sites · @appPools.Count pools</span></div><p class="capability-preview">Sites and pools stay together, but now live in a separate workspace view.</p></section>
                                }
                                @if (hasFileTree)
                                {
                                    <section class="overview-card"><div class="overview-card-head"><h3>File Tree</h3><span class="timestamp-chip">@Model.FileTreeSnapshot.Roots.Count roots</span></div><p class="capability-preview">Browse files and security from a dedicated file tree view.</p></section>
                                }
                                @if (hasUsersAndGroups)
                                {
                                    <section class="overview-card"><div class="overview-card-head"><h3>Users &amp; Groups</h3><span class="timestamp-chip">@users.Count users · @groups.Count groups</span></div><p class="capability-preview">Inspect identities and memberships separately from the dashboard.</p></section>
                                }
                            </div>

                            <div class="tab-panel-body">
                                <section class="change-summary-shell">
                                    <div class="section-heading compact-heading">
                                        <div>
                                            <p class="eyebrow">Snapshot Changes</p>
                                            <h2>What changed since the last capture</h2>
                                        </div>
                                    </div>

                                    @if (changedCapabilities.Count == 0)
                                    {
                                        <p class="empty-state">No capability has two snapshots yet, so there is nothing to compare.</p>
                                    }
                                    else
                                    {
                                        <div class="change-summary-grid">
                                            @foreach (var capability in changedCapabilities)
                                            {
                                                <section class="change-card @(capability.ChangeSummary.HasChanges ? "change-card-hot" : string.Empty)">
                                                    <div class="overview-card-head">
                                                        <h3>@capability.Descriptor.DisplayName</h3>
                                                        <span class="timestamp-chip">@(capability.ChangeSummary.PreviousCollectedUtc?.ToLocalTime().ToString("g") ?? "-")</span>
                                                    </div>
                                                    <p class="capability-preview">@capability.ChangeSummary.Summary</p>
                                                    @if (capability.ChangeSummary.Highlights.Count > 0)
                                                    {
                                                        <div class="change-highlight-list">
                                                            @foreach (var highlight in capability.ChangeSummary.Highlights)
                                                            {
                                                                <span class="change-highlight-chip">@highlight</span>
                                                            }
                                                        </div>
                                                    }
                                                </section>
                                            }
                                        </div>
                                    }
                                </section>

                                <section class="change-summary-shell">
                                    <div class="section-heading compact-heading">
                                        <div>
                                            <p class="eyebrow">Change Feed</p>
                                            <h2>Latest snapshot events</h2>
                                        </div>
                                    </div>

                                    @if (Model.Agent.RecentChanges.Count == 0)
                                    {
                                        <p class="empty-state">No change events have been recorded for this agent yet.</p>
                                    }
                                    else
                                    {
                                        <div class="activity-stream compact-stream">
                                            @foreach (var change in Model.Agent.RecentChanges.Take(8))
                                            {
                                                <article class="activity-item">
                                                    <div class="activity-item-head">
                                                        <div>
                                                            <p class="activity-title">@change.CapabilityKey</p>
                                                            <div class="activity-meta">
                                                                <span>@change.CollectedUtc.ToLocalTime().ToString("g")</span>
                                                                <span>@change.ChangeKind</span>
                                                            </div>
                                                        </div>
                                                        <a asp-page="/Agents/Details"
                                                           asp-route-id="@Model.Agent.AgentId"
                                                           asp-route-section="@DetailsModel.MapCapabilityKeyToSection(change.CapabilityKey)"
                                                           class="btn btn-sm btn-outline-secondary">
                                                            Open capability
                                                        </a>
                                                    </div>
                                                    <p class="capability-preview">@change.Summary</p>
                                                    @if (change.Highlights.Count > 0)
                                                    {
                                                        <div class="change-highlight-list">
                                                            @foreach (var highlight in change.Highlights)
                                                            {
                                                                <span class="change-highlight-chip">@highlight</span>
                                                            }
                                                        </div>
                                                    }
                                                </article>
                                            }
                                        </div>
                                    }
                                </section>

                                <div class="section-heading compact-heading">
                                    <div>
                                        <p class="eyebrow">Recent Activity</p>
                                        <h2>Latest actions</h2>
                                    </div>
                                </div>
                                <div class="data-table-wrap">
                                    <table class="table data-table">
                                        <thead><tr><th>When</th><th>Capability</th><th>Action</th><th>Target</th><th>Status</th><th>Result</th></tr></thead>
                                        <tbody>
                                        @if (Model.Agent.RecentActions.Count == 0)
                                        {
                                            <tr><td colspan="6" class="empty-cell">No actions have been recorded yet.</td></tr>
                                        }
                                        else
                                        {
                                            @foreach (var action in Model.Agent.RecentActions.Take(8))
                                            {
                                                <tr>
                                                    <td>@action.CreatedUtc.ToLocalTime().ToString("g")</td>
                                                    <td>@action.CapabilityKey</td>
                                                    <td>@action.ActionKey</td>
                                                    <td>@(action.TargetKey ?? "-")</td>
                                                    <td><span class="state-pill">@action.Status</span></td>
                                                    <td>@(action.ResultMessage ?? action.ErrorMessage ?? "-")</td>
                                                </tr>
                                            }
                                        }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </article>
                    }
                    else if (Model.SelectedSection == DetailsModel.ServicesSection && hasServices)
                    {
                        <article class="capability-card polished">
                            <header class="capability-header">
                                <div>
                                    <h3>Windows Services</h3>
                                    <p>Operate the services currently visible through this agent filter.</p>
                                </div>
                                <span class="timestamp-chip">@services.Count services</span>
                            </header>
                            <div class="tab-panel-body">
                                @if (serviceState is not null)
                                {
                                    <section class="inline-change-summary">
                                        <p class="inline-change-title">Changes since previous snapshot</p>
                                        <p class="capability-preview">@serviceState.ChangeSummary.Summary</p>
                                    </section>
                                }
                                <partial name="_CapabilityHistory" model="Model.CapabilityHistory" />
                                @if (services.Count == 0)
                                {
                                    <p class="empty-state">No services matched the current filter.</p>
                                }
                                else
                                {
                                    <div class="data-table-wrap">
                                        <table class="table data-table">
                                            <thead><tr><th>Service</th><th>Status</th><th>Type</th><th>Actions</th></tr></thead>
                                            <tbody>
                                            @foreach (var service in services.Take(80))
                                            {
                                                <tr>
                                                    <td><div class="primary-cell">@service.DisplayName</div><div class="muted">@service.ServiceName</div></td>
                                                    <td><span class="state-pill">@service.Status</span></td>
                                                    <td>@service.ServiceType</td>
                                                    <td>
                                                        <form method="post" asp-page-handler="QueueAction" class="inline-form">
                                                            <input type="hidden" name="agentId" value="@Model.Agent.AgentId" />
                                                            <input type="hidden" name="capabilityKey" value="services" />
                                                            <input type="hidden" name="targetKey" value="@service.ServiceName" />
                                                            <input type="hidden" name="section" value="@Model.SelectedSection" />
                                                            <button type="submit" class="btn btn-sm btn-outline-success" name="actionKey" value="start">Start</button>
                                                            <button type="submit" class="btn btn-sm btn-outline-warning" name="actionKey" value="stop">Stop</button>
                                                            <button type="submit" class="btn btn-sm btn-outline-primary" name="actionKey" value="restart">Restart</button>
                                                        </form>
                                                    </td>
                                                </tr>
                                            }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                            </div>
                        </article>
                    }
                    else if (Model.SelectedSection == DetailsModel.TasksSection && hasScheduledTasks)
                    {
                        <article class="capability-card polished">
                            <header class="capability-header">
                                <div>
                                    <h3>Scheduled Tasks</h3>
                                    <p>Run filtered tasks on demand from a dedicated workspace view.</p>
                                </div>
                                <span class="timestamp-chip">@scheduledTasks.Count tasks</span>
                            </header>
                            <div class="tab-panel-body">
                                @if (scheduledTaskState is not null)
                                {
                                    <section class="inline-change-summary">
                                        <p class="inline-change-title">Changes since previous snapshot</p>
                                        <p class="capability-preview">@scheduledTaskState.ChangeSummary.Summary</p>
                                    </section>
                                }
                                <partial name="_CapabilityHistory" model="Model.CapabilityHistory" />
                                @if (scheduledTasks.Count == 0)
                                {
                                    <p class="empty-state">No scheduled tasks matched the current filter.</p>
                                }
                                else
                                {
                                    <div class="data-table-wrap">
                                        <table class="table data-table">
                                            <thead><tr><th>Task</th><th>Status</th><th>Run as</th><th>Command</th><th>Action</th></tr></thead>
                                            <tbody>
                                            @foreach (var task in scheduledTasks.Take(80))
                                            {
                                                var fullTaskName = $"{task.TaskPath}{task.TaskName}";
                                                <tr>
                                                    <td><div class="primary-cell">@task.TaskName</div><div class="muted">@task.TaskPath</div></td>
                                                    <td><span class="state-pill">@task.Status</span></td>
                                                    <td>@(task.RunAsUser ?? "-")</td>
                                                    <td class="truncate-cell">@(task.TaskToRun ?? "-")</td>
                                                    <td>
                                                        <form method="post" asp-page-handler="QueueAction" class="inline-form">
                                                            <input type="hidden" name="agentId" value="@Model.Agent.AgentId" />
                                                            <input type="hidden" name="capabilityKey" value="scheduledTasks" />
                                                            <input type="hidden" name="targetKey" value="@fullTaskName" />
                                                            <input type="hidden" name="section" value="@Model.SelectedSection" />
                                                            <button type="submit" class="btn btn-sm btn-outline-primary" name="actionKey" value="run">Run</button>
                                                        </form>
                                                    </td>
                                                </tr>
                                            }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                            </div>
                        </article>
                    }
                    else if (Model.SelectedSection == DetailsModel.IisSection && hasIis)
                    {
                        <article class="capability-card polished">
                            <header class="capability-header">
                                <div>
                                    <h3>IIS</h3>
                                    <p>Sites and app pools grouped together in one focused area.</p>
                                </div>
                                <span class="timestamp-chip">@sites.Count sites · @appPools.Count pools</span>
                            </header>
                            <div class="tab-panel-body">
                                @if (iisState is not null)
                                {
                                    <section class="inline-change-summary">
                                        <p class="inline-change-title">Changes since previous snapshot</p>
                                        <p class="capability-preview">@iisState.ChangeSummary.Summary</p>
                                    </section>
                                }
                                <partial name="_CapabilityHistory" model="Model.CapabilityHistory" />
                                <div class="split-grid">
                                    <section class="nested-panel">
                                        <div class="panel-heading"><h4>App Pools</h4><span>@appPools.Count total</span></div>
                                        @if (appPools.Count == 0)
                                        {
                                            <p class="empty-state">No app pools matched the current filter.</p>
                                        }
                                        else
                                        {
                                            <div class="data-table-wrap">
                                                <table class="table data-table">
                                                    <thead><tr><th>Name</th><th>State</th><th>Actions</th></tr></thead>
                                                    <tbody>
                                                    @foreach (var pool in appPools.Take(80))
                                                    {
                                                        <tr>
                                                            <td class="primary-cell">@pool.Name</td>
                                                            <td><span class="state-pill">@pool.State</span></td>
                                                            <td>
                                                                <form method="post" asp-page-handler="QueueAction" class="inline-form">
                                                                    <input type="hidden" name="agentId" value="@Model.Agent.AgentId" />
                                                                    <input type="hidden" name="capabilityKey" value="iis" />
                                                                    <input type="hidden" name="targetKey" value="@pool.Name" />
                                                                    <input type="hidden" name="section" value="@Model.SelectedSection" />
                                                                    <button type="submit" class="btn btn-sm btn-outline-success" name="actionKey" value="appPool.start">Start</button>
                                                                    <button type="submit" class="btn btn-sm btn-outline-warning" name="actionKey" value="appPool.stop">Stop</button>
                                                                    <button type="submit" class="btn btn-sm btn-outline-primary" name="actionKey" value="appPool.recycle">Recycle</button>
                                                                </form>
                                                            </td>
                                                        </tr>
                                                    }
                                                    </tbody>
                                                </table>
                                            </div>
                                        }
                                    </section>

                                    <section class="nested-panel">
                                        <div class="panel-heading"><h4>Sites</h4><span>@sites.Count total</span></div>
                                        @if (sites.Count == 0)
                                        {
                                            <p class="empty-state">No IIS sites matched the current filter.</p>
                                        }
                                        else
                                        {
                                            <div class="data-table-wrap">
                                                <table class="table data-table">
                                                    <thead><tr><th>Name</th><th>State</th><th>Bindings</th><th>Actions</th></tr></thead>
                                                    <tbody>
                                                    @foreach (var site in sites.Take(80))
                                                    {
                                                        <tr>
                                                            <td class="primary-cell">@site.Name</td>
                                                            <td><span class="state-pill">@site.State</span></td>
                                                            <td>@string.Join(", ", site.Bindings ?? [])</td>
                                                            <td>
                                                                <form method="post" asp-page-handler="QueueAction" class="inline-form">
                                                                    <input type="hidden" name="agentId" value="@Model.Agent.AgentId" />
                                                                    <input type="hidden" name="capabilityKey" value="iis" />
                                                                    <input type="hidden" name="targetKey" value="@site.Name" />
                                                                    <input type="hidden" name="section" value="@Model.SelectedSection" />
                                                                    <button type="submit" class="btn btn-sm btn-outline-success" name="actionKey" value="site.start">Start</button>
                                                                    <button type="submit" class="btn btn-sm btn-outline-warning" name="actionKey" value="site.stop">Stop</button>
                                                                </form>
                                                            </td>
                                                        </tr>
                                                    }
                                                    </tbody>
                                                </table>
                                            </div>
                                        }
                                    </section>
                                </div>
                            </div>
                        </article>
                    }
                    else if (Model.SelectedSection == DetailsModel.FileTreeSection && hasFileTree)
                    {
                        <article class="capability-card polished">
                            <header class="capability-header">
                                <div>
                                    <h3>File Tree</h3>
                                    <p>Browse configured roots in a dedicated pane.</p>
                                </div>
                                <span class="timestamp-chip">@Model.FileTreeSnapshot.Roots.Count roots</span>
                            </header>
                            <div class="tab-panel-body">
                                @if (fileTreeState is not null)
                                {
                                    <section class="inline-change-summary">
                                        <p class="inline-change-title">Changes since previous snapshot</p>
                                        <p class="capability-preview">@fileTreeState.ChangeSummary.Summary</p>
                                    </section>
                                }
                                <partial name="_CapabilityHistory" model="Model.CapabilityHistory" />
                                @if (Model.FileTreeSnapshot.Roots.Count == 0)
                                {
                                    <p class="empty-state">No file tree roots are configured or reachable on this agent.</p>
                                }
                                else
                                {
                                    <div class="tree-grid">
                                        @foreach (var root in Model.FileTreeSnapshot.Roots)
                                        {
                                            var rows = Model.BuildFileTreeRows(root.Nodes);
                                            <section class="nested-panel">
                                                <div class="panel-heading"><h4>@root.RootPath</h4><span>@rows.Count entries</span></div>
                                                @if (!string.IsNullOrWhiteSpace(root.Owner) || root.Permissions.Count > 0)
                                                {
                                                    <details class="tree-security-panel root-security-block">
                                                        <summary class="tree-security-summary">Root security</summary>
                                                        <div class="tree-security-body">
                                                            @if (!string.IsNullOrWhiteSpace(root.Owner))
                                                            {
                                                                <span class="tree-security-line">Owner: @root.Owner</span>
                                                            }
                                                            @if (root.Permissions.Count > 0)
                                                            {
                                                                <div class="tree-security-chips">
                                                                    @foreach (var permission in root.Permissions)
                                                                    {
                                                                        <span class="security-chip">@permission</span>
                                                                    }
                                                                </div>
                                                            }
                                                        </div>
                                                    </details>
                                                }
                                                @if (rows.Count == 0)
                                                {
                                                    <p class="empty-state">This root is empty or the configured depth reached no visible items.</p>
                                                }
                                                else
                                                {
                                                    <div class="tree-browser">
                                                        <partial name="_FileTreeNodes" model="root.Nodes" />
                                                    </div>
                                                }
                                            </section>
                                        }
                                    </div>
                                }
                            </div>
                        </article>
                    }
                    else if (Model.SelectedSection == DetailsModel.UsersAndGroupsSection && hasUsersAndGroups)
                    {
                        <article class="capability-card polished">
                            <header class="capability-header">
                                <div>
                                    <h3>Users &amp; Groups</h3>
                                    <p>Inspect local server identities and the members attached to each group.</p>
                                </div>
                                <span class="timestamp-chip">@users.Count users · @groups.Count groups</span>
                            </header>
                            <div class="tab-panel-body">
                                @if (usersAndGroupsState is not null)
                                {
                                    <section class="inline-change-summary">
                                        <p class="inline-change-title">Changes since previous snapshot</p>
                                        <p class="capability-preview">@usersAndGroupsState.ChangeSummary.Summary</p>
                                    </section>
                                }
                                <partial name="_CapabilityHistory" model="Model.CapabilityHistory" />
                                <div class="split-grid">
                                    <section class="nested-panel">
                                        <div class="panel-heading"><h4>Local Users</h4><span>@users.Count total</span></div>
                                        @if (users.Count == 0)
                                        {
                                            <p class="empty-state">No local users were returned by this agent.</p>
                                        }
                                        else
                                        {
                                            <div class="data-table-wrap">
                                                <table class="table data-table">
                                                    <thead><tr><th>User</th><th>Status</th><th>Password</th><th>Last Logon</th></tr></thead>
                                                    <tbody>
                                                    @foreach (var user in users.Take(120))
                                                    {
                                                        var passwordMode = user.PasswordRequired ? (user.PasswordExpires ? "Required · Expires" : "Required · No expiry") : "Not required";
                                                        <tr>
                                                            <td>
                                                                <div class="primary-cell">@user.Name</div>
                                                                <div class="muted">@(!string.IsNullOrWhiteSpace(user.FullName) ? user.FullName : user.Description ?? "-")</div>
                                                            </td>
                                                            <td><span class="state-pill">@(user.Enabled ? "Enabled" : "Disabled")</span></td>
                                                            <td>@passwordMode</td>
                                                            <td>@(!string.IsNullOrWhiteSpace(user.LastLogonRaw) ? user.LastLogonRaw : "-")</td>
                                                        </tr>
                                                    }
                                                    </tbody>
                                                </table>
                                            </div>
                                        }
                                    </section>

                                    <section class="nested-panel">
                                        <div class="panel-heading"><h4>Local Groups</h4><span>@groups.Count total</span></div>
                                        @if (groups.Count == 0)
                                        {
                                            <p class="empty-state">No local groups were returned by this agent.</p>
                                        }
                                        else
                                        {
                                            <div class="group-stack">
                                                @foreach (var group in groups.Take(80))
                                                {
                                                    <details class="group-card">
                                                        <summary class="group-card-summary">
                                                            <div class="group-card-title">
                                                                <strong>@group.Name</strong>
                                                                <span class="muted">@(!string.IsNullOrWhiteSpace(group.Description) ? group.Description : "No description")</span>
                                                            </div>
                                                            <span class="timestamp-chip">@group.Members.Count members</span>
                                                        </summary>

                                                        <div class="group-card-body">
                                                            @if (group.Members.Count == 0)
                                                            {
                                                                <p class="empty-state">This group has no visible members in the current snapshot.</p>
                                                            }
                                                            else
                                                            {
                                                                <div class="member-list">
                                                                    @foreach (var member in group.Members)
                                                                    {
                                                                        <div class="member-pill">
                                                                            <strong>@member.Name</strong>
                                                                            <span>@(member.ObjectClass ?? "principal")@(string.IsNullOrWhiteSpace(member.PrincipalSource) ? string.Empty : $" · {member.PrincipalSource}")</span>
                                                                        </div>
                                                                    }
                                                                </div>
                                                            }
                                                        </div>
                                                    </details>
                                                }
                                            </div>
                                        }
                                    </section>
                                </div>
                            </div>
                        </article>
                    }
                    else if (Model.SelectedSection == DetailsModel.ActionsSection)
                    {
                        <article class="capability-card polished">
                            <header class="capability-header">
                                <div>
                                    <h3>Actions</h3>
                                    <p>Review the execution trail for this agent and cancel queued work before it is leased.</p>
                                </div>
                                <span class="timestamp-chip">@Model.Agent.RecentActions.Count recent actions</span>
                            </header>
                            <div class="tab-panel-body">
                                @if (Model.Agent.RecentActions.Count == 0)
                                {
                                    <p class="empty-state">No actions have been recorded for this agent yet.</p>
                                }
                                else
                                {
                                    <div class="data-table-wrap">
                                        <table class="table data-table">
                                            <thead><tr><th>Created</th><th>Capability</th><th>Action</th><th>Target</th><th>Status</th><th>Attempts</th><th>Result</th><th>Control</th></tr></thead>
                                            <tbody>
                                            @foreach (var action in Model.Agent.RecentActions)
                                            {
                                                <tr>
                                                    <td>@action.CreatedUtc.ToLocalTime().ToString("g")</td>
                                                    <td>@action.CapabilityKey</td>
                                                    <td>@action.ActionKey</td>
                                                    <td>@(action.TargetKey ?? "-")</td>
                                                    <td><span class="state-pill">@action.Status</span></td>
                                                    <td>@action.AttemptCount</td>
                                                    <td>@(action.ResultMessage ?? action.ErrorMessage ?? "-")</td>
                                                    <td>
                                                        @if (string.Equals(action.Status, "Pending", StringComparison.OrdinalIgnoreCase))
                                                        {
                                                            <form method="post" asp-page-handler="CancelAction" class="inline-form">
                                                                <input type="hidden" name="agentId" value="@Model.Agent.AgentId" />
                                                                <input type="hidden" name="actionId" value="@action.ActionId" />
                                                                <input type="hidden" name="section" value="@Model.SelectedSection" />
                                                                <button type="submit" class="btn btn-sm btn-outline-danger">Cancel</button>
                                                            </form>
                                                        }
                                                        else
                                                        {
                                                            <span class="muted">Locked</span>
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                            </div>
                        </article>
                    }
                    else
                    {
                        <article class="capability-card polished">
                            <p class="empty-state">This section is not available for the selected agent.</p>
                        </article>
                    }
                </div>
            </div>
        </section>
    </div>
}
