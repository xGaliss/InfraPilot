{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Central": {
    "EnrollmentKey": "infra-dev-enroll",
    "OperatorApiKey": "infra-dev-operator",
    "AutoApproveAgents": false,
    "ActionLeaseSeconds": 90,
    "HealthyThresholdSeconds": 90,
    "DelayedThresholdSeconds": 300,
    "SnapshotRetentionDays": 30,
    "ChangeEventRetentionDays": 30,
    "ActionRetentionDays": 60,
    "CleanupIntervalMinutes": 60,
    "DatabasePath": "data\\central\\infrapilot.db"
  },
  "AllowedHosts": "*"
}
